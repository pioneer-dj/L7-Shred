{
  "listen": ":443",
  "mode": "dual",
  "primary": "udp",
  "fallback": "tcp",
  "secret_key": "base64_encoded_32_byte_secret_key_here",
  "cipher": "aes-256-gcm",
  "post_quantum": true,
  "masks": ["webrtc", "quic", "teams"],
  "padding": {
    "enabled": true,
    "min": 32,
    "max": 288,
    "rotate_interval": 30
  },
  "jitter": {
    "enabled": true,
    "mean_ms": 2,
    "stddev_ms": 1,
    "loss_rate": 0.005
  },
  "chaffing": {
    "enabled": true,
    "interval": 5,
    "targets": ["google.com", "microsoft.com", "apple.com", "cloudflare.com"]
  },
  "session": {
    "timeout": 300,
    "max_sessions": 1000
  }
}